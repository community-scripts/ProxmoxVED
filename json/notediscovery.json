        {
            "type": "default",
            "script": "ct/notediscovery.sh",
            "resources": {
                "cpu": 1,
                "ram": 512,
                "hdd": 4,
                "os": "Debian",
                "version": "13"
            }
        }
    ],
    "default_credentials": {
        "username": null,
        "password": "admin"
    },
    "notes": [
        {
            "text": "Authentication is disabled by default. Enable it in /opt/notediscovery/config.yaml and change the default password.",
            "type": "warning"
        },
        {
            "text": "Notes are stored as plain Markdown files in /opt/notediscovery/data.",
            "type": "info"
        }
