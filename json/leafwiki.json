{
    "name": "LeafWiki",
    "slug": "leafwiki",
    "categories": [
        12
    ],
    "date_created": "2026-07-06",
    "type": "ct",
    "updateable": true,
    "privileged": false,
    "has_arm": true,
    "interface_port": 8080,
    "documentation": "https://github.com/perber/leafwiki",
    "website": "https://leafwiki.com",
    "logo": "https://cdn.jsdelivr.net/gh/selfhst/icons@main/webp/leafwiki.webp",
    "config_path": "/etc/leafwiki/.env",
    "description": "LeafWiki is a self-hosted wiki built as a single Go binary with SQLite and Markdown stored on disk. No Node.js, no Redis, no Postgres — just a binary and a data directory.",
    "install_methods": [
        {
            "type": "default",
            "script": "ct/leafwiki.sh",
            "resources": {
                "cpu": 1,
                "ram": 512,
                "hdd": 4,
                "os": "Debian",
                "version": "13"
            }
        }
    ],
    "default_credentials": {
        "username": "admin",
        "password": "auto-generated"
    },
    "notes": [
        {
            "text": "Admin password is stored in /etc/leafwiki/.env.",
            "type": "info"
        },
        {
            "text": "Wiki data and Markdown files are stored in /opt/leafwiki/data.",
            "type": "info"
        }
    ]
}