{
  "name": "LocalAI",
  "slug": "localai",
  "categories": [
    20
  ],
  "date_created": "2026-03-04",
  "type": "ct",
  "updateable": true,
  "privileged": false,
  "interface_port": 8080,
  "documentation": "https://localai.io/installation/",
  "website": "https://localai.io/",
  "logo": "https://cdn.jsdelivr.net/gh/selfhst/icons@main/webp/localai.webp",
  "config_path": "/etc/localai/localai.env",
  "description": "LocalAI is a self-hosted OpenAI-compatible API server for running LLM, image, and audio models locally.",
  "install_methods": [
    {
      "type": "default",
      "script": "ct/localai.sh",
      "resources": {
        "cpu": 4,
        "ram": 8192,
        "hdd": 64,
        "os": "Debian",
        "version": "13"
      }
    }
  ],
  "default_credentials": {
    "username": null,
    "password": null
  },
  "notes": [
    {
      "text": "Installs LocalAI from the latest Linux amd64 release binary and runs it as a systemd service.",
      "type": "info"
    },
    {
      "text": "If an AMD GPU is detected, the script configures ROCm Debian repositories and installs ROCm. GPU acceleration requires /dev/kfd passthrough.",
      "type": "info"
    },
    {
      "text": "Default API endpoint: http://<container-ip>:8080",
      "type": "info"
    }
  ]
}
