validate_container_id() {
  [[ "${1:-}" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]
}

get_valid_container_id() {
  echo "${1:-$CT_NAME}"
}

validate_hostname() {
  local hostname="${1:-}"
  [[ -n "$hostname" ]] || return 1
  [[ "$hostname" =~ ^[a-zA-Z0-9][a-zA-Z0-9-]{0,62}$ ]]
}

validate_mac_address() {
  local mac="${1:-}"
  [[ "$mac" =~ ^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$ ]]
}

validate_vlan_tag() {
  local tag="${1:-}"
  [[ "$tag" =~ ^[0-9]+$ ]] || return 1
  ((tag >= 0 && tag <= 4094))
}

validate_mtu() {
  local mtu="${1:-}"
  [[ "$mtu" =~ ^[0-9]+$ ]] || return 1
  ((mtu >= 576 && mtu <= 9216))
}

validate_ipv6_address() {
  local ip="${1:-}"
  [[ "$ip" == "dhcp" || "$ip" == "auto" || "$ip" == "none" ]] && return 0
  [[ "$ip" =~ : ]]
}

validate_bridge() {
  local bridge="${1:-}"
  [[ -z "$bridge" ]] && return 1
  incus network show "$bridge" >/dev/null 2>&1
}

validate_ip_address() {
  local ip="${1:-}"
  [[ "$ip" == "dhcp" ]] && return 0
  [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}(/[0-9]{1,2})?$ ]]
}

validate_gateway_ip() {
  local ip="${1:-}"
  [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]
}

validate_gateway_in_subnet() { return 0; }
validate_timezone() { [[ -n "${1:-}" ]]; }

validate_tags() {
  local tags="${1:-}"
  [[ -z "$tags" ]] && return 0
  [[ "$tags" =~ ^[a-zA-Z0-9._-]+(\;[a-zA-Z0-9._-]+)*$ ]]
}

ip_to_int() {
  local a b c d
  IFS=. read -r a b c d <<<"${1:-0.0.0.0}"
  echo $((a * 256 ** 3 + b * 256 ** 2 + c * 256 + d))
}

int_to_ip() {
  local ip=${1:-0}
  echo "$(((ip >> 24) & 255)).$(((ip >> 16) & 255)).$(((ip >> 8) & 255)).$((ip & 255))"
}

is_ip_range() { [[ "${1:-}" == *-* ]]; }

resolve_ip_from_range() {
  local range="${1:-}"
  if [[ "$range" =~ ^([0-9]+\.[0-9]+\.[0-9]+\.)([0-9]+)-([0-9]+)$ ]]; then
    local base="${BASH_REMATCH[1]}"
    local start="${BASH_REMATCH[2]}"
    echo "${base}${start}"
    return 0
  fi
  echo "$range"
}

get_current_ip() {
  command -v get_lxc_ip >/dev/null 2>&1 && get_lxc_ip || hostname -I 2>/dev/null | awk '{print $1}'
}

# ==============================================================================
# SECTION 9: BARE FUNCTION ALIASES (for CT script compatibility)
# ==============================================================================
#
# These aliases allow CT scripts to use the same function names as Proxmox
# scripts (start, build_container, description, variables) without
# modification. color, catch_errors, header_info are already provided by
# incus_install_compat_aliases in incus-core.func / incus-tools.func.
# ==============================================================================

# start() - Handles both host (create) and container (update) contexts
start() {
  if command -v incus &>/dev/null && [[ -z "${_INCUS_INSIDE_CONTAINER:-}" ]]; then
    # Running on Incus host - proceed to build_container
    return 0
  else
    # Running inside container - update mode
    VERBOSE=${var_verbose:-"no"}
    if [[ "${VERBOSE}" == "yes" ]]; then
      STD=""
    else
      STD="silent"
    fi
    ensure_profile_loaded
    update_script
    cleanup_lxc
  fi
}

# build_container() - Creates Incus container and runs install script
build_container() {
  incus_build_container
}

# description() - Shows completion summary
description() {
  incus_description
}

# variables() - Initializes variables (alias for incus_variables)
variables() {
  incus_variables
}