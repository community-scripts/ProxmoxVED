incus_advanced_step_selection() {
  if ! incus_can_use_whiptail; then
    echo "fallback"
    return
  fi

  whiptail --backtitle "Incus Helper Scripts" --title "ADVANCED SETTINGS STEPS" --checklist \
    "Choose the steps you want to edit" 24 86 16 \
    "name" "Container Name" ON \
    "cpu" "CPU Cores" ON \
    "ram" "RAM (MiB)" ON \
    "disk" "Disk (GiB)" ON \
    "profile" "Incus Profile" ON \
    "network" "Network Bridge" ON \
    "ip4" "IPv4 Address/DHCP" ON \
    "ip6" "IPv6 Address/Auto" OFF \
    "mac" "MAC Address" OFF \
    "vlan" "VLAN Tag" OFF \
    "mtu" "MTU" OFF \
    "storage" "Storage Pool" ON \
    "tags" "Tags" ON \
    "features" "Nesting/FUSE/TUN/GPU/Privileged" ON \
    "ssh" "SSH Key Injection" OFF \
    "preflight" "Run Preflight Checks" OFF \
    3>&1 1>&2 2>&3 || true
}

advanced_settings() {
  stop_spinner
  log_msg "[INFO] Applying advanced settings"

  INCUS_RUN_PRECHECKS=0
  export INCUS_RUN_PRECHECKS

  local selected
  selected="$(incus_advanced_step_selection)"

  if [[ "$selected" == "fallback" ]]; then
    selected='"name" "cpu" "ram" "disk" "profile" "network" "ip4" "ip6" "mac" "vlan" "mtu" "storage" "tags" "features" "ssh"'
  fi

  local has_step
  has_step() { [[ " $selected " == *" \"$1\" "* ]]; }

  local v
  if has_step "name"; then
    v=$(incus_prompt_input "CONTAINER NAME" "Container Name" "${CT_NAME}")
    [[ -n "$v" ]] && CT_NAME=$(echo "${v,,}" | tr -d ' ' | tr '_' '-')
  fi

  if has_step "cpu"; then
    v=$(incus_prompt_input "CPU CORES" "CPU Cores" "${CORE_COUNT}")
    [[ "$v" =~ ^[0-9]+$ ]] && CORE_COUNT="$v" || msg_warn "Invalid CPU value, keeping ${CORE_COUNT}"
  fi

  if has_step "ram"; then
    v=$(incus_prompt_input "RAM" "RAM (MiB)" "${RAM_SIZE}")
    [[ "$v" =~ ^[0-9]+$ ]] && RAM_SIZE="$v" || msg_warn "Invalid RAM value, keeping ${RAM_SIZE}"
  fi

  if has_step "disk"; then
    v=$(incus_prompt_input "DISK" "Disk (GiB)" "${DISK_SIZE}")
    [[ "$v" =~ ^[0-9]+$ ]] && DISK_SIZE="$v" || msg_warn "Invalid Disk value, keeping ${DISK_SIZE}"
  fi

  if has_step "profile"; then
    v=$(incus_prompt_input "PROFILE" "Profile" "${PROFILE}")
    [[ -n "$v" ]] && PROFILE="$v"
  fi

  if has_step "network"; then
    BRG="$(incus_select_network "${BRG}")"
    echo -e "${BRIDGE}${BOLD}${DGN}Network Bridge: ${BGN}${BRG}${CL}"
  fi

  if has_step "ip4"; then
    v=$(incus_prompt_input "IPV4" "IPv4 (dhcp or x.x.x.x)" "${NET}")
    [[ -n "$v" ]] && NET="$v"
  fi

  if has_step "ip6"; then
    v=$(incus_prompt_input "IPV6" "IPv6 (auto/none/or address)" "${IPV6_ADDR}")
    [[ -n "$v" ]] && IPV6_ADDR="$v"
  fi

  if has_step "mac"; then
    v=$(incus_prompt_input "MAC" "MAC Address (empty=auto)" "${MAC}")
    [[ -n "$v" ]] && MAC="$v"
  fi

  if has_step "vlan"; then
    v=$(incus_prompt_input "VLAN" "VLAN Tag (empty=none)" "${VLAN_TAG}")
    [[ -n "$v" ]] && VLAN_TAG="$v"
  fi

  if has_step "mtu"; then
    v=$(incus_prompt_input "MTU" "MTU (empty=default)" "${MTU}")
    [[ -n "$v" ]] && MTU="$v"
  fi

  if has_step "storage"; then
    v=$(incus_prompt_input "STORAGE" "Storage Pool" "${STORAGE_POOL}")
    [[ -n "$v" ]] && STORAGE_POOL="$v"
  fi

  if has_step "tags"; then
    v=$(incus_prompt_input "TAGS" "Tags (; separated)" "${TAGS}")
    [[ -n "$v" ]] && TAGS="$v"
  fi

  if has_step "features"; then
    if incus_prompt_confirm "FEATURE" "Enable nesting?" "$([[ "${ENABLE_NESTING}" == "1" ]] && echo y || echo n)"; then ENABLE_NESTING=1; else ENABLE_NESTING=0; fi
    if incus_prompt_confirm "FEATURE" "Enable FUSE?" "$([[ "${ENABLE_FUSE}" == "yes" ]] && echo y || echo n)"; then ENABLE_FUSE=yes; else ENABLE_FUSE=no; fi
    if incus_prompt_confirm "FEATURE" "Enable TUN?" "$([[ "${ENABLE_TUN}" == "yes" ]] && echo y || echo n)"; then ENABLE_TUN=yes; else ENABLE_TUN=no; fi
    if incus_prompt_confirm "FEATURE" "Enable GPU passthrough flag?" "$([[ "${ENABLE_GPU}" == "yes" ]] && echo y || echo n)"; then ENABLE_GPU=yes; else ENABLE_GPU=no; fi
    if incus_prompt_confirm "FEATURE" "Use unprivileged container?" "$([[ "${UNPRIVILEGED}" == "1" ]] && echo y || echo n)"; then UNPRIVILEGED=1; else UNPRIVILEGED=0; fi
  fi

  if has_step "ssh"; then
    if incus_prompt_confirm "SSH" "Inject SSH key?" "$([[ "${SSH}" == "yes" ]] && echo y || echo n)"; then
      SSH=yes
      if [[ -z "${SSH_AUTHORIZED_KEY:-}" ]]; then
        v=$(incus_prompt_input "SSH KEY" "Public SSH key (single line)" "")
        [[ -n "$v" ]] && SSH_AUTHORIZED_KEY="$v"
      fi
    else
      SSH=no
    fi
  fi

  if has_step "preflight"; then
    INCUS_RUN_PRECHECKS=1
  elif [[ "$selected" == "fallback" ]]; then
    if incus_prompt_confirm "PREFLIGHT" "Run pre-flight checks?" "n"; then
      INCUS_RUN_PRECHECKS=1
    fi
  else
    INCUS_RUN_PRECHECKS=0
  fi

  msg_ok "Applied advanced settings"
}
